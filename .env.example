# Docker-образ бэкенда (на сервере CI подставляет sha-тег)
DOCKER_IMAGE=username/backend:latest

# Порт NestJS — должен совпадать с mapping в docker-compose (4545:4545)
PORT=4545

# Postgres: в docker-compose хост — db; на сервере укажите внешний хост
DATABASE_URL=postgresql://user:password@db:5432/postgres

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres
